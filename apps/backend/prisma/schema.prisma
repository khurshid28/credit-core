generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  MODERATOR
  DIRECTOR
  ADMIN
}

enum ProductType {
  REAL_ESTATE
  AUTO
}

enum CaseStatus {
  DRAFT
  MODERATION
  DIRECTOR_REVIEW
  ADMIN_FINALIZE
  FINALIZED
  REJECTED
}

enum WorkflowDecision {
  SUBMIT
  APPROVE
  RETURN
  FINALIZE
}

enum DocumentType {
  NOTARY
  SCAN
  PASSPORT
  COLLATERAL_PHOTO
  TECH_PASSPORT
  DIRECTOR_FINAL
  GENERATED_PDF
  CHAT
  OTHER
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  symbol    String   @unique // filial id symbol, e.g. "BR"
  region    String?
  users     User[]
  // Moderators responsible for this branch (many-to-many; a branch may have
  // several moderators and a moderator may cover several branches).
  moderators User[]  @relation("BranchModerators")
  cases     CreditCase[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  login        String   @unique
  passwordHash String
  plainPassword String? // admin-visible credential (internal tool — see note)
  avatarPath   String?
  phone        String?
  role         Role
  branch       Branch?  @relation(fields: [branchId], references: [id])
  branchId     String?
  // Branches this moderator is responsible for (m-n, see Branch.moderators).
  moderatedBranches Branch[] @relation("BranchModerators")
  isActive     Boolean  @default(true)
  createdCases CreditCase[] @relation("CaseCreatedBy")
  documents    Document[]
  events       WorkflowEvent[]
  sentMessages Message[] @relation("MessageSender")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([branchId])
}

model CreditCase {
  id           String      @id @default(cuid())
  number       String      @unique
  productType  ProductType
  status       CaseStatus  @default(DRAFT)
  amount       Decimal?    @db.Decimal(18, 2)
  termMonths   Int?
  katmPrice    Decimal?    @db.Decimal(18, 2)

  branch       Branch?     @relation(fields: [branchId], references: [id])
  branchId     String?
  createdBy    User        @relation("CaseCreatedBy", fields: [createdById], references: [id])
  createdById  String

  borrower     Borrower?
  guarantors   Guarantor[]
  collaterals  Collateral[]
  valuationAct ValuationAct?
  documents    Document[]
  events       WorkflowEvent[]
  importJobs   ImportJob[]
  messages     Message[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([branchId])
}

model Borrower {
  id             String   @id @default(cuid())
  case           CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId         String   @unique
  fullName       String
  passportSeries String?
  passportNumber String?
  pinfl          String?
  birthDate      DateTime?
  address        String?  @db.Text
  phone          String?
}

// Kafil (guarantor) — a case may have several.
model Guarantor {
  id             String   @id @default(cuid())
  case           CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId         String
  fullName       String
  passportSeries String?
  passportNumber String?
  pinfl          String?
  phone          String?
  relation       String? // qarz oluvchiga munosabati

  @@index([caseId])
}

// Unified collateral — a case can have several (e.g. 2 flats + 1 car).
model Collateral {
  id               String      @id @default(cuid())
  case             CreditCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId           String
  type             ProductType // REAL_ESTATE | AUTO
  agreedValue      Decimal?    @db.Decimal(18, 2)
  agreedValueWords String?     @db.Text

  // Real estate fields
  address          String?  @db.Text
  registryNo       String?
  propertyType     String?
  cadastreNo       String?
  registrationDate DateTime?
  totalAreaM2      Float?
  livingAreaM2     Float?
  roomNames        String?  @db.Text
  roomCount        Int?

  // Auto fields
  techPassportNo   String?
  techPassportDate DateTime?
  model            String?
  stateNumber      String?
  bodyType         String?
  bodyNo           String?
  engineNo         String?
  chassis          String?
  color            String?
  year             Int?
  mileage          Int?

  owners    CollateralOwner[]
  createdAt DateTime @default(now())

  @@index([caseId])
}

model CollateralOwner {
  id             String   @id @default(cuid())
  collateral     Collateral @relation(fields: [collateralId], references: [id], onDelete: Cascade)
  collateralId   String
  fullName       String
  passportSeries String?
  passportNumber String?
  pinfl          String?
  sharePercent   Float?
}

model ValuationAct {
  id               String   @id @default(cuid())
  case             CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId           String   @unique
  actNo            String?
  actDate          DateTime?
  agreedValue      Decimal? @db.Decimal(18, 2)
  agreedValueWords String?  @db.Text
}

model Document {
  id          String       @id @default(cuid())
  case        CreditCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId      String
  collateralId String?     // optional: ties a photo/doc to a specific collateral
  title       String?      // human label given on upload (per-collateral docs)
  description String?      @db.Text // optional longer note
  type        DocumentType
  fileName    String
  storagePath String
  mimeType    String?
  isGenerated Boolean      @default(false)
  uploadedBy  User?        @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  // Legacy single-attachment back-relation (Message.documentId).
  message     Message?     @relation("MessageDoc")
  // Multi-attachment: a chat message can carry several files.
  attachedTo  Message?     @relation("MessageAttachments", fields: [messageId], references: [id], onDelete: SetNull)
  messageId   String?
  createdAt   DateTime     @default(now())

  @@index([caseId])
  @@index([messageId])
}

model Message {
  id         String     @id @default(cuid())
  case       CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId     String
  sender     User       @relation("MessageSender", fields: [senderId], references: [id])
  senderId   String
  text       String?    @db.Text
  toRole     Role?
  toUserId   String?    // directed to a single user (private to them + sender)
  document   Document?  @relation("MessageDoc", fields: [documentId], references: [id], onDelete: SetNull)
  documentId String?    @unique
  attachments Document[] @relation("MessageAttachments")
  readBy     String?    @db.Text // comma-separated userIds who have read it
  createdAt  DateTime   @default(now())

  @@index([caseId])
}

model WorkflowEvent {
  id         String           @id @default(cuid())
  case       CreditCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId     String
  fromStatus CaseStatus?
  toStatus   CaseStatus
  decision   WorkflowDecision
  actor      User             @relation(fields: [actorId], references: [id])
  actorId    String
  role       Role
  comment    String?          @db.Text
  createdAt  DateTime         @default(now())

  @@index([caseId])
}

model ImportJob {
  id             String   @id @default(cuid())
  sourceFileName String
  status         String   @default("PARSED")
  parsedJson     Json
  case           CreditCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  caseId         String?
  createdAt      DateTime @default(now())
}
