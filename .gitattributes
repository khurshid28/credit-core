# Files that run on the Linux server must keep LF endings regardless of the
# committer's OS — CRLF would break bash scripts and nginx/Docker configs.
*.sh        text eol=lf
deploy/**   text eol=lf
Dockerfile* text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
# Docker's .dockerignore parser doesn't strip CR — CRLF would break every pattern.
.dockerignore text eol=lf
