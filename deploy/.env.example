# Production env for docker-compose. Copy to deploy/.env and fill in real values.
# deploy/.env is gitignored — NEVER commit real secrets.

# MySQL (internal to the compose network; not exposed to the host in prod).
MYSQL_ROOT_PASSWORD=change-me-strong-password

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Backend → mysql service on the compose network.
DATABASE_URL=mysql://root:change-me-strong-password@mysql:3306/credit_core

# Baked into every web build. Protocol-relative (//host) so the API scheme follows the page:
# an http:// page calls the http API, an https:// page calls the https API (no mixed content).
# nginx serves both :80 and :443, so either works. (Pin to https://api.creditcore.uz if you
# want to force TLS from the client.)
VITE_API_URL=//api.creditcore.uz

# CORS — the 4 role origins, both schemes (nginx serves http and https).
CORS_ORIGINS=http://operator.creditcore.uz,https://operator.creditcore.uz,http://moderator.creditcore.uz,https://moderator.creditcore.uz,http://director.creditcore.uz,https://director.creditcore.uz,http://admin.creditcore.uz,https://admin.creditcore.uz

# Let's Encrypt contact — nginx terminates TLS in-stack; certbot issues/renews the cert.
CERTBOT_EMAIL=khurshidi2827@gmail.com
