# Build any one of the 4 web apps and serve it via nginx.
# Usage: docker build --build-arg APP=web-operator -f deploy/Dockerfile.web .
ARG APP=web-operator

FROM node:22-slim AS build
ARG APP
ARG VITE_API_URL=https://api.creditcore.uz
ENV VITE_API_URL=$VITE_API_URL
WORKDIR /app
COPY . .
# ci = reproducible + faster than install; .dockerignore keeps the context lean.
RUN npm ci
RUN npm run build -w @credit-core/$APP

FROM nginx:1.27-alpine
ARG APP
COPY --from=build /app/apps/$APP/dist /usr/share/nginx/html
# SPA fallback
RUN printf 'server {\n  listen 80;\n  root /usr/share/nginx/html;\n  location / { try_files $uri /index.html; }\n}\n' > /etc/nginx/conf.d/default.conf
EXPOSE 80
