# Production env for docker-compose. Copy to deploy/.env and fill in real values.
# deploy/.env is gitignored — NEVER commit real secrets.

# MySQL (internal to the compose network; not exposed to the host in prod).
MYSQL_ROOT_PASSWORD=change-me-strong-password

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Backend → mysql service on the compose network.
DATABASE_URL=mysql://root:change-me-strong-password@mysql:3306/credit_core

# Baked into every web build — must be the PUBLIC https origin (the host proxy serves TLS).
VITE_API_URL=https://api.creditcore.uz

# CORS — the 4 role origins.
CORS_ORIGINS=https://operator.creditcore.uz,https://moderator.creditcore.uz,https://director.creditcore.uz,https://admin.creditcore.uz

# TLS is terminated by the server's own reverse proxy / panel (not by this stack),
# so there is no CERTBOT_EMAIL here — issue/renew certs there.
